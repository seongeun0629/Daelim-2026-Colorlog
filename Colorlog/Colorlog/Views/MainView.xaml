<Window x:Class="Colorlog.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Colorlog"
        xmlns:views="clr-namespace:Colorlog.Views.Pages"
        xmlns:viewmodel ="clr-namespace:Colorlog.ViewModels"
        mc:Ignorable="d"
        Title="Colorlog" Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <DataTemplate x:Name="BeautyLogPage" DataType="{x:Type viewmodel:BeautyLogViewModel}">
            <views:BeautyLogView/>
        </DataTemplate>
        
        <Storyboard x:Key="OpenSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                         Storyboard.TargetProperty="Width"
                         From="0" To="260" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CloseSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                         Storyboard.TargetProperty="Width"
                         From="260" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" x:Name="SidebarBorder" Width="0"
            Background="{StaticResource SidebarBrush}" 
            BorderThickness="0,0,1,0" BorderBrush="{StaticResource DividerBrush}"
            Canvas.ZIndex="10" HorizontalAlignment="Left">
            <DockPanel Width="260">
                <StackPanel DockPanel.Dock="Top" Margin="30,40,30,40">
                    <TextBlock Text="Colorlog" FontSize="28" FontWeight="Black" 
                           Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
                <ListBox x:Name="SidebarListBox" BorderThickness="0"
                         Background="Transparent" Margin="10,0" SelectedIndex="0"
                         SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" CornerRadius="10" Margin="5,4" Padding="20,15" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource SelectedBgBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource SelectedBgBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBoxItem Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" Margin="0,0,15,0" FontSize="18"/>
                            <TextBlock Text="나의 컬러 홈" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="LiveAnalysis">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" Margin="0,0,15,0" FontSize="18"/>
                            <TextBlock Text="실시간 컬러 분석" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" Margin="0,0,15,0" FontSize="18"/>
                            <TextBlock Text="컬러 히스토리" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="BeautyLog">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💄" Margin="0,0,15,0" FontSize="18"/>
                            <TextBlock Text="퍼스널 뷰티템" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,15,0" FontSize="18"/>
                            <TextBlock Text="서비스 설정" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20">
                <Button x:Name="BtnToggle" Content="☰" FontSize="20" 
                        Background="Transparent" BorderBrush="Transparent"
                        Cursor="Hand" Click="BtnToggle_Click" Margin="0,0,20,0"/>

                <TextBlock Text="오늘의 컬러를 찾아보세요" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20">
                <ContentControl x:Name ="ContentArea" Content="{Binding CurrentView}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
